#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
plugin_root="$(cd "$script_dir/.." && pwd)"
safe_install="$plugin_root/bin/safe-install"

if [[ -x "$safe_install" ]]; then
  doctor_output="$("$safe_install" doctor 2>&1 || true)"
else
  doctor_output="safe-install binary was not found at $safe_install"
fi

message="safe-install plugin is enabled.

Package-manager install commands should resolve through the plugin's bin wrappers:
- pnpm install, pnpm add, pnpm update, pnpm exec, pnpm dlx, pnpx
- npm install, npm ci, npm exec, npm init, npx
- bun install, bun add, bun update, bun run, bun x, bunx
- uv sync, uv add, uv pip, uv tool, uv python, uv run
- pip install, pip wheel, pip download

If this is an already-open Codex or coding-agent shell after safe-install was installed or updated, run eval \"\$(safe-install reload)\" and then safe-install doctor before dependency work.

For Node, Bun, and uv package executables, use pnpm exec, pnpm dlx, npx, bun run, bunx, uv run, or uv tool run instead of host paths or direct node_modules/.bin guesses.

For uv project work, keep the project's declared Python constraint intact. The wrapper uses a generic uv image and a container-local .venv, so do not downgrade requires-python or similar project metadata just to match the wrapper image.

Python package installs use a project .venv. After pip install succeeds, run python or python3 normally from the project; do not retry with python3 -m pip --user, --break-system-packages, or manual venv activation.

The first real install will try to start OrbStack or Docker Desktop on macOS when Docker is not reachable.

Current status:
$doctor_output"

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped_message="$(escape_for_json "$message")"

if [[ -n "${CURSOR_PLUGIN_ROOT:-}" ]]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_message"
elif [[ -n "${CLAUDE_PLUGIN_ROOT:-}" ]]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_message"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$escaped_message"
fi
