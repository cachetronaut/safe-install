#!/usr/bin/env bash
set -euo pipefail

tool="$(basename "$0")"
cmd="${1:-}"

if [[ "${SAFE_INSTALL_BYPASS:-0}" == "1" ]]; then
  cmd="__pass_through__"
fi

# Sandbox only commands that fetch & execute untrusted package code.
# `run` invokes local, trusted code (package.json scripts / local files) and
# must stay on the host — sandboxing it breaks git-aware tooling. bun fetches
# remote code via `x`/`create`, which stay sandboxed.
case "$cmd" in
  install|i|add|remove|rm|update|up|x|create|init)
    exec safe-install --pm "$tool" -- "$@"
    ;;
esac

shim_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IFS=':' read -r -a path_parts <<< "$PATH"
for dir in "${path_parts[@]}"; do
  # Skip every safe-install shim dir (own dir, a case-variant of it, or a
  # second install) so passthrough resolves the real host tool instead of
  # looping wrapper -> wrapper forever when no real tool is on PATH.
  [[ -e "$dir/safe-install" ]] && continue
  if [[ -x "$dir/$tool" ]]; then
    exec "$dir/$tool" "$@"
  fi
done

printf '%s wrapper: real %s not found on PATH\n' "$tool" "$tool" >&2
exit 127
