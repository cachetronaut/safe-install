#!/usr/bin/env bash
set -euo pipefail

tool="$(basename "$0")"

find_project_venv_python() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -x "$dir/.venv/bin/$tool" ]]; then
      printf '%s\n' "$dir/.venv/bin/$tool"
      return 0
    fi
    if [[ -x "$dir/.venv/bin/python" ]]; then
      printf '%s\n' "$dir/.venv/bin/python"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

if [[ "${SAFE_INSTALL_BYPASS:-0}" != "1" ]]; then
  if venv_python="$(find_project_venv_python)"; then
    exec "$venv_python" "$@"
  fi
fi

shim_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IFS=':' read -r -a path_parts <<< "$PATH"
for dir in "${path_parts[@]}"; do
  [[ "$dir" == "$shim_dir" ]] && continue
  if [[ -x "$dir/$tool" ]]; then
    exec "$dir/$tool" "$@"
  fi
done

printf '%s wrapper: real %s not found on PATH\n' "$tool" "$tool" >&2
exit 127
